"""
Stock Return and Risk Analysis Using Simulated Data
Course: Financial Data Analysis / Statistics
University: Xi'an Jiaotong-Liverpool University
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy import stats

# Set random seed to ensure reproducible results
np.random.seed(123)

# --------------------------
# 1. Simulate Stock Data
# --------------------------
num_days = 252
tickers = ['AAPL', 'MSFT', 'GOOGL', 'TSLA']

# Simulate daily returns
returns = pd.DataFrame({
    'AAPL': np.random.normal(0.0010, 0.020, num_days),
    'MSFT': np.random.normal(0.0009, 0.018, num_days),
    'GOOGL': np.random.normal(0.0008, 0.021, num_days),
    'TSLA': np.random.normal(0.0015, 0.035, num_days)
})

# Simulate price series starting from 100
prices = 100 * (1 + returns).cumprod()

# --------------------------
# 2. Descriptive Statistics
# --------------------------
print("===== Simulated Stock Returns Preview =====")
print(returns.head())

print("\n===== Descriptive Statistics =====")
print(returns.describe().round(4))

# --------------------------
# 3. Annualized Performance
# --------------------------
annual_return = returns.mean() * 252
annual_volatility = returns.std() * np.sqrt(252)
sharpe_ratio = annual_return / annual_volatility

metrics = pd.DataFrame({
    'Annual_Return': annual_return,
    'Annual_Volatility': annual_volatility,
    'Sharpe_Ratio': sharpe_ratio
})

print("\n===== Annual Performance Metrics =====")
print(metrics.round(4))

# --------------------------
# 4. Maximum Drawdown
# --------------------------
def calculate_max_drawdown(price_series):
    peak = price_series.cummax()
    drawdown = (price_series - peak) / peak
    return drawdown.min()

max_dd = prices.apply(calculate_max_drawdown)
print("\n===== Maximum Drawdown =====")
print(max_dd.round(4))

# --------------------------
# 5. Correlation Matrix
# --------------------------
corr_matrix = returns.corr()
print("\n===== Return Correlation Matrix =====")
print(corr_matrix.round(4))

# --------------------------
# 6. t-test for Mean Return
# --------------------------
print("\n===== One-Sample t-test (H0: mean return = 0) =====")
for tick in tickers:
    t_stat, p_value = stats.ttest_1samp(returns[tick], 0)
    print(f"{tick}: t = {t_stat:.4f}, p-value = {p_value:.4f}")

# --------------------------
# 7. Visualization
# --------------------------
plt.figure(figsize=(12, 10))

# Price trend
plt.subplot(2, 1, 1)
prices.plot(ax=plt.gca())
plt.title('Simulated Stock Price Trends')
plt.grid(True)

# Return distribution
plt.subplot(2, 1, 2)
for tick in tickers:
    plt.hist(returns[tick], bins=30, alpha=0.4, label=tick)
plt.title('Distribution of Daily Returns')
plt.legend()
plt.grid(True)

plt.tight_layout()
plt.show()
